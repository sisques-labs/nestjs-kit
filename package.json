{
  "name": "@sisques-labs/nestjs-kit",
  "version": "1.3.1",
  "description": "NestJS Kit with DDD/CQRS base classes, value objects, repository abstractions, and GraphQL utilities",
  "author": "JSisques",
  "private": false,
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mongodb": {
      "require": "./dist/entrypoints/mongodb.js",
      "import": "./dist/entrypoints/mongodb.js",
      "types": "./dist/entrypoints/mongodb.d.ts"
    },
    "./typeorm": {
      "require": "./dist/entrypoints/typeorm.js",
      "import": "./dist/entrypoints/typeorm.js",
      "types": "./dist/entrypoints/typeorm.d.ts"
    },
    "./graphql": {
      "require": "./dist/entrypoints/graphql.js",
      "import": "./dist/entrypoints/graphql.js",
      "types": "./dist/entrypoints/graphql.d.ts"
    },
    "./kafka": {
      "require": "./dist/entrypoints/kafka.js",
      "import": "./dist/entrypoints/kafka.js",
      "types": "./dist/entrypoints/kafka.d.ts"
    },
    "./mcp": {
      "require": "./dist/entrypoints/mcp.js",
      "import": "./dist/entrypoints/mcp.js",
      "types": "./dist/entrypoints/mcp.d.ts"
    },
    "./metrics": {
      "require": "./dist/entrypoints/metrics.js",
      "import": "./dist/entrypoints/metrics.js",
      "types": "./dist/entrypoints/metrics.d.ts"
    },
    "./messaging": {
      "require": "./dist/entrypoints/messaging.js",
      "import": "./dist/entrypoints/messaging.js",
      "types": "./dist/entrypoints/messaging.d.ts"
    },
    "./registered-enums": {
      "require": "./dist/shared/transport/graphql/enums/shared-registered-enums.graphql.js",
      "import": "./dist/shared/transport/graphql/enums/shared-registered-enums.graphql.js",
      "types": "./dist/shared/transport/graphql/enums/shared-registered-enums.graphql.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "husky && pnpm run build",
    "build": "nest build && tsc-alias -p tsconfig.tsc-alias.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "prepublishOnly": "npm run build",
    "release": "semantic-release"
  },
  "peerDependencies": {
    "@apollo/server": ">=4.0.0",
    "@kafkajs/confluent-schema-registry": ">=3.0.0",
    "@nestjs/apollo": ">=12.0.0",
    "@nestjs/axios": ">=3.0.0",
    "@nestjs/common": ">=10.0.0",
    "@nestjs/config": ">=3.0.0",
    "@nestjs/core": ">=10.0.0",
    "@nestjs/graphql": ">=12.0.0",
    "@nestjs/typeorm": ">=10.0.0",
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "@willsoto/nestjs-prometheus": ">=6.0.0",
    "express": ">=4.0.0",
    "graphql": ">=16.0.0",
    "graphql-query-complexity": ">=0.12.0",
    "graphql-type-json": ">=0.3.0",
    "kafkajs": ">=2.0.0",
    "mongodb": ">=6.0.0",
    "prom-client": ">=15.0.0",
    "reflect-metadata": ">=0.2.0",
    "rxjs": ">=7.0.0",
    "typeorm": ">=0.3.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@apollo/server": {
      "optional": true
    },
    "@kafkajs/confluent-schema-registry": {
      "optional": true
    },
    "@nestjs/apollo": {
      "optional": true
    },
    "@nestjs/axios": {
      "optional": true
    },
    "@nestjs/config": {
      "optional": true
    },
    "@nestjs/graphql": {
      "optional": true
    },
    "@nestjs/typeorm": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@willsoto/nestjs-prometheus": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "graphql": {
      "optional": true
    },
    "graphql-query-complexity": {
      "optional": true
    },
    "graphql-type-json": {
      "optional": true
    },
    "kafkajs": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    },
    "typeorm": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@nestjs/cqrs": "^11.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@apollo/server": "^4.0.0",
    "@kafkajs/confluent-schema-registry": "^4.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@nestjs/apollo": "^12.0.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/graphql": "^12.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.2",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "express": "^5.2.1",
    "graphql": "^16.0.0",
    "graphql-query-complexity": "^0.12.0",
    "graphql-type-json": "^0.3.2",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "kafkajs": "^2.2.4",
    "mongodb": "^6.0.0",
    "prettier": "^3.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "semantic-release": "^24.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.0",
    "typescript": "^5.1.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
